# Backend env (đọc bởi server.js qua dotenv)

NODE_ENV=development

# PostgreSQL
DB_HOST=postgres
DB_PORT=5432
DB_NAME=restaurant_db
DB_USER=postgres
DB_PASSWORD=postgres

# JWT — BẮT BUỘC tạo ngẫu nhiên trước khi deploy production!
# Sinh giá trị: openssl rand -base64 48
# Phải >= 32 ký tự và JWT_SECRET phải KHÁC REFRESH_SECRET.
JWT_SECRET=REPLACE_ME_WITH_RANDOM_32_PLUS_CHARS
JWT_EXPIRES=15m
REFRESH_SECRET=REPLACE_ME_WITH_DIFFERENT_RANDOM_32_PLUS_CHARS
REFRESH_EXPIRES=30d

# CORS — danh sách origin được phép, cách nhau bằng dấu phẩy.
# Bắt buộc trong production. Để trống ở dev sẽ cho phép tất cả (kèm warning).
ALLOWED_ORIGINS=http://localhost:8080,http://localhost:8081

# MinIO
MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=restaurant
MINIO_PUBLIC_URL=http://localhost:9000

PORT=3000
