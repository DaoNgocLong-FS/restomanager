# =====================================================
# RestoManager - Cấu hình triển khai (Docker Compose)
# Sao chép file này thành `.env` rồi chỉnh sửa.
#
# !!! BẮT BUỘC trước khi chạy production:
#   - Sinh JWT_SECRET và REFRESH_SECRET ngẫu nhiên (>= 32 ký tự, KHÁC NHAU)
#     openssl rand -base64 48
#   - Đặt ALLOWED_ORIGINS theo domain thật của bạn
#   - Đổi DB_PASSWORD và MinIO credentials
# =====================================================

NODE_ENV=development

# --- PostgreSQL ---
DB_NAME=restaurant_db
DB_USER=postgres
DB_PASSWORD=postgres
DB_PORT_HOST=5432

# --- JWT ---
# CHẠY:  openssl rand -base64 48     để tạo giá trị ngẫu nhiên cho mỗi secret.
# JWT_SECRET và REFRESH_SECRET phải KHÁC NHAU.
JWT_SECRET=REPLACE_ME_WITH_RANDOM_32_PLUS_CHARS
JWT_EXPIRES=15m
REFRESH_SECRET=REPLACE_ME_WITH_DIFFERENT_RANDOM_32_PLUS_CHARS
REFRESH_EXPIRES=30d

# --- CORS ---
# Danh sách domain được phép gọi API & socket, ngăn cách bằng dấu phẩy.
# Bắt buộc ở production.
ALLOWED_ORIGINS=http://localhost:8080,http://localhost:8081

# --- MinIO ---
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=restaurant
MINIO_PORT_HOST=9000
MINIO_CONSOLE_PORT=9001
MINIO_PUBLIC_URL=http://localhost:9000

# --- Cổng dịch vụ ---
BACKEND_PORT_HOST=3000
FRONTEND_PORT_HOST=8080
