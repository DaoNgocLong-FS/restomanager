{
  "expo": {
    "name": "RestoManager",
    "slug": "restomanager-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "splash": { "backgroundColor": "#0d5c63" },
